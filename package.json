{
  "name": "quality-analytics-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --configLoader runner",
    "build": "vite build --configLoader runner",
    "preview": "vite preview --host 127.0.0.1",
    "desktop": "npm run build && electron .",
    "desktop:pack": "npm run build && powershell -ExecutionPolicy Bypass -File scripts/package-portable.ps1",
    "desktop:installer": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "5.0.4",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.qms.qualityanalytics",
    "productName": "QMS质量分析平台",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
